{
  "MockWorkflow": {
    "id": "_test_workflow",
    "type": "workflow.Workflow",
    "name": "Empty workflow for testing",
    "steps": []
  },
  "PII_Transcriber": {
    "type": "provider.DirFileProvider",
    "steps": [
      {
        "id": "img_iter",
        "type": "iterator.Iterator",
        "name": "File Iterator",
        "steps": [
          {
            "id": "pii_classifier",
            "type": "classifier.MockClassifier",
            "name": "Has PII Classifier",
            "register_on": ["img_iter"]
          },
          {
            "type": "gate.LabelTestGate",
            "name": "Has PII Gate",
            "settings": { "component": "pii_classifier", "label": ["okay"] },
            "true_steps": [
              {
                "type": "transcriber.GeminiTranscriber",
                "name": "Cloud Image Transcriber"
              }
            ],
            "false_steps": [
              {
                "type": "transcriber.LMStudioTranscriber",
                "name": "Local Image Transcriber",
                "settings": { "model": "qwen/qwen3.5-9b" }
              }
            ]
          }
        ]
      }
    ],
    "next_steps": [{ "id": "iter_debug", "type": "utils.DebugStep" }]
  },
  "FileSystemStorage": {
    "type": "storage.FileSystemStorage",
    "settings": {
      "directory": "results"
    }
  },
  "YoloDetectAndAnnotate": {
    "id": "yolo_detect",
    "type": "segmenter.YoloSegmenter",
    "name": "YOLO Detect + Annotated Preview",
    "settings": { "model": "yolo11n.pt", "confidence": 0.25 },
    "next_steps": [
      {
        "id": "yolo_annotate",
        "type": "annotator.ImageBoxAnnotator",
        "name": "Annotated Detection Image"
      }
    ]
  }
}
