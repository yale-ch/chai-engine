{
  "PII_Transcriber": {
    "type": "provider.DirFileProvider",
    "steps": [
      {
        "id": "img_iter",
        "type": "iterator.Iterator",
        "name": "File Iterator",
        "steps": [
          {
            "id": "pii_classifier",
            "type": "classifier.Classifier",
            "name": "Has PII Classifier",
            "register_on": ["img_iter"]
          },
          {
            "type": "gate.LabelTestGate",
            "name": "Has PII Gate",
            "settings": { "component": "pii_classifier", "label": ["okay"] },
            "true_steps": [
              {
                "type": "transcriber.GeminiTranscriber",
                "name": "Cloud Image Transcriber"
              }
            ],
            "false_steps": [
              {
                "type": "transcriber.LMSTranscriber",
                "name": "Local Image Transcriber",
                "settings": { "model": "qwen/qwen3.5-9b" }
              }
            ]
          }
        ]
      }
    ],
    "next_steps": [{ "id": "iter_debug", "type": "utils.DebugStep" }]
  },
  "FileSystemStorage": {
    "type": "storage.FileSystemStorage",
    "settings": {
      "directory": "results"
    }
  }
}
